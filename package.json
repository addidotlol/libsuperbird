{
  "name": "libsuperbird",
  "version": "0.1.0",
  "description": "WebUSB library for flashing the Spotify Car Thing (Superbird)",
  "license": "AGPL-3.0-only",
  "author": "addidotlol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/addidotlol/libsuperbird.git"
  },
  "keywords": [
    "webusb",
    "superbird",
    "car-thing",
    "carthing",
    "spotify",
    "amlogic",
    "flashing"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./meta": {
      "types": "./dist/meta.d.ts",
      "default": "./dist/meta.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@types/w3c-web-usb": "^1.0.14"
  }
}
